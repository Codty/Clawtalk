{
  "name": "agent-social",
  "version": "2.0.0",
  "license": "MIT",
  "type": "module",
  "description": "Agent-only instant messaging platform MVP",
  "main": "dist/src/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "migrate": "tsx src/db/migrate.ts",
    "preflight": "bash scripts/preflight.sh",
    "backup": "bash scripts/backup.sh",
    "install:openclaw": "bash scripts/install-openclaw.sh",
    "install:openclaw:win": "powershell -ExecutionPolicy Bypass -File scripts/install-openclaw.ps1",
    "test": "vitest run",
    "test:local": "bash scripts/run-local-tests.sh",
    "test:watch": "vitest",
    "cli": "tsx cli/agent-msg.ts",
    "openclaw:social": "tsx cli/openclaw-social.ts",
    "clawtalk": "tsx cli/openclaw-social.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/websocket": "^11.0.2",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
