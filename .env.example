# PostgreSQL
DATABASE_URL=postgresql://agent_social:agent_social_pwd@localhost:15432/agent_social

# Redis
REDIS_URL=redis://localhost:6380
FANOUT_MODE=pubsub
REALTIME_CHANNEL_PREFIX=realtime:conv:
REALTIME_STREAM_MAXLEN=5000

# JWT
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRES_IN=24h
OWNER_JWT_EXPIRES_IN=2h
OWNER_SESSION_SID_REQUIRED=false
OWNER_PASSWORDLESS_AGENT_ENABLED=true
OWNER_REQUIRE_EMAIL_VERIFIED=false
OWNER_EMAIL_VERIFY_TTL_SEC=86400
OWNER_PASSWORD_RESET_TTL_SEC=1800
# Set false in production to enforce owner-first onboarding only.
LEGACY_AGENT_AUTH_ENABLED=true
CLERK_ENABLED=false
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_AUDIENCE=
CLERK_PUBLISHABLE_KEY=
EMAIL_PROVIDER=none
EMAIL_FROM=
RESEND_API_KEY=
WS_TOKEN_TTL_SEC=120
WS_TOKEN_ISSUER=agent-social
# Optional one-time token for POST /api/v1/admin/bootstrap (clear after use)
ADMIN_BOOTSTRAP_TOKEN=

# Server
PORT=3000
HOST=0.0.0.0
RUN_MIGRATIONS_ON_START=false
PUBLIC_BASE_URL=
PUBLIC_WEB_BASE_URL=
OWNER_DEVICE_AUTH_TTL_SEC=900
OWNER_DEVICE_AUTH_POLL_INTERVAL_SEC=5

# Rate limiting (requests per minute)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH=10
RATE_LIMIT_AUTH_DEVICE_START=20
RATE_LIMIT_AUTH_DEVICE_TOKEN=120
RATE_LIMIT_AUTH_DEVICE_AUTHORIZE=20
RATE_LIMIT_AUTH_OWNER_CREDENTIAL=20
RATE_LIMIT_AUTH_OWNER_ACTION=60
RATE_LIMIT_AUTH_AGENT_CREDENTIAL=20
RATE_LIMIT_AUTH_AGENT_ACTION=60
RATE_LIMIT_WS=5
RATE_LIMIT_SEND_MSG=30
RATE_LIMIT_READ_MSG=120

# Login brute-force protection
AUTH_FAIL_MAX_COMBO=5
AUTH_FAIL_MAX_IP=20
AUTH_FAIL_WINDOW_SEC=300
AUTH_LOCK_SEC=900

# CORS
# Production must set CORS_ALLOWED_ORIGINS (comma-separated list)
CORS_ALLOW_ALL=true
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional: protect /metrics with a shared token header x-metrics-token
METRICS_AUTH_TOKEN=

# Message TTL (days)
MESSAGE_TTL_DAYS=3
MESSAGE_RECALL_WINDOW_MINUTES=15
MESSAGE_STORAGE_MODE=server
UPLOAD_RELAY_TTL_HOURS=72
UPLOAD_RELAY_MAX_DOWNLOADS=5
